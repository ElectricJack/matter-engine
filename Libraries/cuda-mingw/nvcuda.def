; Libraries/cuda-mingw/nvcuda.def
; Minimal export list for CUDA driver API functions used by rt_lighting.cpp.
; Generated import lib lets MinGW link against nvcuda.dll (ships with NVIDIA driver).
LIBRARY nvcuda.dll
EXPORTS
cuInit
cuDeviceGet
cuDevicePrimaryCtxRetain
cuDevicePrimaryCtxRelease_v2
cuCtxSetCurrent
cuCtxSynchronize
cuMemAlloc_v2
cuMemFree_v2
cuMemcpyHtoD_v2
cuMemcpyDtoH_v2
cuGraphicsGLRegisterImage
cuGraphicsMapResources
cuGraphicsUnmapResources
cuGraphicsUnregisterResource
cuGraphicsSubResourceGetMappedArray
cuSurfObjectCreate
cuSurfObjectDestroy
