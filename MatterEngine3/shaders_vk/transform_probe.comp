#version 460

layout(local_size_x = 1, local_size_y = 1, local_size_z = 1) in;

layout(std430, set = 0, binding = 0) buffer TransformProbe {
    mat4 transform_matrix;
    vec4 input_value;
    vec4 output_value;
} probe;

void main() {
    probe.output_value = probe.transform_matrix * probe.input_value;
}
