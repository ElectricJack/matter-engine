# Build artifacts
*.o
*.obj
*.d
*.a
*.so
*.dylib
*.dll
*.exe
obj/
build/

# Per-project compiled binaries (named after the project)
BasicWindowApp/cube_app
SurfaceLib/surface_app
ObjectAllocatorLib/objectallocator
OpenParticleSurfaceLib/open_particle_surface
SpatialQueryLib/spatialquerylib
GPURayTraceExample/gpu_raytrace
GPURayTraceExample/shader_preprocessor
ParticleDynamicsExample/particle_dynamics
MatterSurfaceLib/matter_surface_lib
MatterSurfaceLib/shader_preprocessor

# Misc
SurfaceLib/test_config
*.ini

# Editor / OS
.DS_Store
.vscode/
.idea/
*.swp

# Claude Code / assistant tool state (regenerated locally)
.claude/

# Allow raylib's vendored static lib through the *.a exclusion (committed builds)
!Libraries/raylib/build/**/libraylib.a
!Libraries/raylib/src/libraylib.a

# Vendored TBB (Libraries/autoremesher_core/thirdparty/tbb) ships its own
# build system under `build/` -- the .inc / Makefile source files there are
# NOT artifacts and must be tracked. Un-ignore the whole tree, then re-ignore
# the versioned per-config build output subdirs it emits at build time.
!Libraries/autoremesher_core/thirdparty/tbb/build/
!Libraries/autoremesher_core/thirdparty/tbb/build/**
Libraries/autoremesher_core/thirdparty/tbb/build/linux_*_debug/
Libraries/autoremesher_core/thirdparty/tbb/build/linux_*_release/
Libraries/autoremesher_core/thirdparty/tbb/build/*_debug/
Libraries/autoremesher_core/thirdparty/tbb/build/*_release/
# Allow box3d's prebuilt Linux and MinGW static libs
!Libraries/box3d/libbox3d.a
!Libraries/box3d/build-mingw/libbox3d.a
MatterEngine3/viewer/cache
MatterSurfaceLib/parts

# MatterEngine3 compiled binaries and bake caches
MatterEngine3/viewer/viewer
MatterEngine3/tests/*_tests
MatterEngine3/tests/*_tests_*
MatterEngine3/tests/*_check
MatterEngine3/tests/example_world
MatterEngine3/tests/parts/
MatterEngine3/tests/*.log
MatterEngine3/tests/sandbox/

# viewer-integration tests (share viewer's object graph; live in viewer/ for
# now — see followup on moving to tests/)
MatterEngine3/viewer/*_tests

# Other project test binaries (compiled from same-named *.cpp drivers)
MatterSurfaceLib/tests/*_tests
MeshChartingLib/tests/*_tests
Libraries/autoremesher_core/tests/smoke_cube
Libraries/autoremesher_core/tests/quad_to_tri_test

# ObjectAllocatorLib and SpatialQueryLib test binaries + object dirs
SpatialQueryLib/spatial_hash_tests
SpatialQueryLib/bvh_tests
ObjectAllocatorLib/object_allocator_tests
# `make TARGET=linux` (build-all.sh convention) emits a binary named `linux`
ObjectAllocatorLib/linux
SpatialQueryLib/linux

# Transient screenshots + sentinel files (FIFO shot capture)
*.png.done
MatterEngine3/viewer/*.png
MatterEngine3/viewer/shots_forestfloor/
MatterEngine3/tools/shots_task6/
shots/
# (no trailing slash: shaders is a symlink in fresh checkouts, a dir otherwise)
MatterEngine3/viewer/shaders

# Local backups / imposter test outputs / world bake data
*.bak
imposters/
MatterEngine3/examples/world_demo/WorldData/*.gtex

# Screenshots/ is a checked-in folder — override the broad `shots/` rule above
# for the specific subdir that happens to be named `shots`.
!Screenshots/shots/
MatterViewer/cache
MatterViewer/viewer
MatterEngine3/parts
parts
